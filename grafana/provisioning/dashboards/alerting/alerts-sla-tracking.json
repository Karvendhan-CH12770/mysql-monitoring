    {
      "id": 4,
      "type": "stat",
      "title": "Servers Online",
      "description": "Percentage of all monitored servers currently reachable",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 80 },
              { "color": "yellow", "value": 95 },
              { "color": "green",  "value": 100 }
            ]
          },
          "unit": "percent",
          "decimals": 1,
          "noValue": "N/A"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "count(up == 1) / count(up) * 100",
          "instant": true,
          "legendFormat": "Online %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "alertlist",
      "title": "Current Alert State — All Teams",
      "description": "Live view of all firing, pending and error alerts across every team",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 4 },
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["team", "severity"],
        "groupMode": "tags",
        "maxItems": 50,
        "sortOrder": 1,
        "stateFilter": {
          "error":   true,
          "firing":  true,
          "noData":  true,
          "normal":  false,
          "pending": true
        },
        "viewMode": "list"
      },
      "targets": []
    },

