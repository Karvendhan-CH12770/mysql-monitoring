  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Firing Alerts",
      "description": "Number of alerts currently in firing state across all teams",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "unit": "short",
          "noValue": "0"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)",
          "instant": true,
          "legendFormat": "Firing",
          "refId": "A"
        }
      ]
    },

