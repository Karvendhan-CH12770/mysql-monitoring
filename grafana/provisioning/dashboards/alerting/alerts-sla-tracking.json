    {
      "id": 13,
      "type": "row",
      "title": "Alert Analysis",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }
    },

    {
      "id": 14,
      "type": "table",
      "title": "Per-Server Uptime — Live Status",
      "description": "Current up/down status for every monitored target with team and environment labels",
      "gridPos": { "h": 9, "w": 13, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "options": {
        "cellHeight": "sm",
        "footer": { "countRows": false, "fields": "", "reducer": ["sum"], "show": false },
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Status" }]
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "left",
            "cellOptions": { "type": "auto" },
            "filterable": true,
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "mappings", "value": [
                { "options": { "0": { "color": "red",   "index": 0, "text": "DOWN"   } }, "type": "value" },
                { "options": { "1": { "color": "green", "index": 1, "text": "UP"     } }, "type": "value" }
              ]}
            ]
          },
          { "matcher": { "id": "byName", "options": "Time"        }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "__name__"    }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "job"         }, "properties": [{ "id": "displayName",   "value": "Job"    }] },
          { "matcher": { "id": "byName", "options": "instance"    }, "properties": [{ "id": "displayName",   "value": "Instance" }] },
          { "matcher": { "id": "byName", "options": "server_name" }, "properties": [{ "id": "displayName",   "value": "Server Name" }] },
          { "matcher": { "id": "byName", "options": "team"        }, "properties": [{ "id": "displayName",   "value": "Team"   }] },
          { "matcher": { "id": "byName", "options": "environment" }, "properties": [{ "id": "displayName",   "value": "Env"    }] },
          { "matcher": { "id": "byName", "options": "Value"       }, "properties": [{ "id": "displayName",   "value": "Status" }] }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "up",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "valueLabel": "Value" } },
        {
          "id": "organize",
          "options": {
            "renameByName": { "Value": "Status" }
          }
        }
      ]
    },

    {
      "id": 15,
      "type": "barchart",
      "title": "Firing Alert Duration — Currently Firing (seconds)",
      "description": "Time each alert has been continuously firing. Longer bars = older unresolved alerts.",
      "gridPos": { "h": 9, "w": 11, "x": 13, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "options": {
        "barRadius": 0.03,
        "barWidth": 0.7,
        "colorByField": "severity",
        "fillOpacity": 80,
        "gradientMode": "none",
        "groupWidth": 0.7,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": { "mode": "single", "sort": "none" },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 200
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "hideFrom": { "legend": false, "tooltip": false, "viz": false }, "lineWidth": 1 },
          "unit": "s"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "sort_desc(time() - ALERTS_FOR_STATE)",
          "instant": true,
          "legendFormat": "{{alertname}} | {{team}}",
          "refId": "A"
        }
      ]
    },

    {
