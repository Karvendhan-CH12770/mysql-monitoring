    {
      "id": 7,
      "type": "gauge",
      "title": "Windows Servers",
      "gridPos": { "h": 7, "w": 4, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 100, "min": 90,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 95 },
              { "color": "yellow", "value": 99 },
              { "color": "green",  "value": 99.9 }
            ]
          },
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-uid" },
          "expr": "avg_over_time(up{job=~\"$windows_job\"}[$__range]) * 100",
          "instant": true,
          "legendFormat": "{{server_name}}",
          "refId": "A"
        }
      ]
    },

