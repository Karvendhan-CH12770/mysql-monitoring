      "pluginVersion": "12.3.1",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "editorMode": "code",
          "expr": "min(up{job=~\"$job\", environment=~\"$environment\", team=~\"$team\", server_name=~\"$server_name\"})",
