          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Usage %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } },
              { "id": "max", "value": 100 }
