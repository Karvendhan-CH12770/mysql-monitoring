          "format": "table",
          "instant": true,
          "refId": "MAX"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * (mysql_global_status_threads_connected{job=~\"$job\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"} / mysql_global_variables_max_connections{job=~\"$job\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"})",
          "format": "table",
          "instant": true,
          "refId": "PERCENT"
        }
      ],
      "title": "Connection Status by Server",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "server_name", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true,
              "environment 1": true, "environment 2": true, "environment 3": true,
              "instance 1": true, "instance 2": true, "instance 3": true,
              "job 1": true, "job 2": true, "job 3": true,
              "team 1": true, "team 2": true, "team 3": true,
              "server_name 2": true, "server_name 3": true
            },
            "indexByName": {
              "server_name 1": 0,
              "Value #CONNECTED": 1,
              "Value #MAX": 2,
              "Value #PERCENT": 3
            },
            "renameByName": {
              "server_name 1": "Server Name",
              "Value #CONNECTED": "Active Connections",
              "Value #MAX": "Max Connections",
              "Value #PERCENT": "Usage %"
            }
          }
        }
      ],
      "type": "table"
    },
