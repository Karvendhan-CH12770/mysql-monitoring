    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "auto", "cellOptions": { "type": "auto" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Usage %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "decimals", "value": 2 },
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "color", "value": { "mode": "continuous-GrYlRd" } },
              { "id": "max", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Max Connections" },
            "properties": [{ "id": "unit", "value": "short" }]
          },
          {
            "matcher": { "id": "byName", "options": "Active Connections" },
            "properties": [{ "id": "unit", "value": "short" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Usage %" }]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (server_name) (pg_stat_activity_count{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"})",
          "format": "table",
          "instant": true,
          "refId": "ACTIVE"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (server_name) (pg_settings_max_connections{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"})",
          "format": "table",
          "instant": true,
          "refId": "MAX"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (server_name) (pg_stat_activity_count{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"}) / sum by (server_name) (pg_settings_max_connections{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"}) * 100",
          "format": "table",
          "instant": true,
          "refId": "PERCENT"
        }
      ],
      "title": "Connection Status by Server",
      "transformations": [
        { "id": "joinByField", "options": { "byField": "server_name", "mode": "outer" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true,
              "job 1": true, "job 2": true, "job 3": true,
              "instance 1": true, "instance 2": true, "instance 3": true,
              "team 1": true, "team 2": true, "team 3": true,
              "environment 1": true, "environment 2": true, "environment 3": true,
              "server_name 2": true, "server_name 3": true
            },
            "indexByName": {
              "server_name 1": 0,
              "Value #ACTIVE": 1,
              "Value #MAX": 2,
              "Value #PERCENT": 3
            },
            "renameByName": {
              "server_name 1": "Server Name",
              "Value #ACTIVE": "Active Connections",
              "Value #MAX": "Max Connections",
              "Value #PERCENT": "Usage %"
            }
          }
        }
      ],
      "type": "table"
    },
