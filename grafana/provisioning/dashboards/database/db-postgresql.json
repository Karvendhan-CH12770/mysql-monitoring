        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (server_name) (pg_stat_activity_count{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"}) / sum by (server_name) (pg_settings_max_connections{job=\"postgres_servers\", team=~\"$team\", environment=~\"$environment\", server_name=~\"$server_name\"}) * 100",
          "legendFormat": "{{server_name}}",
          "refId": "A"
        }
