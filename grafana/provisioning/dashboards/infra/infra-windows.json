          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(rate(windows_logical_disk_reads_total{volume=~\"C:|D:\", team=~\"$team\", environment=~\"$environment\", os=~\"$os\", server_name=~\"$server_name\"}[5m]))",
          "legendFormat": "Read",
